<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.accel.api.ai.AiDao">

	<resultMap id="brandOptionResultMap" type="AiBrand">
		<id     property="brandId"   column="brand_id"/>
		<result property="brandName" column="brand_name"/>
	</resultMap>

	<resultMap id="vehicleResultMap" type="Vehicle">
		<id     property="vehicleId"   column="vehicle_id"/>
		<result property="vehicleName"   column="vehicle_name"/>
		<result property="vehicleNameKo" column="vehicle_name_ko"/>
		<result property="category"    column="category"/>
		<result property="segment"     column="segment"/>
		<result property="bodyType"    column="body_type"/>
		<result property="seating"     column="seating"/>
		<result property="minPrice"    column="min_price"/>
		<result property="maxPrice"    column="max_price"/>
		<result property="description" column="description"/>
		<result property="summary"     column="summary"/>
		<result property="brandId"     column="brand_id"/>
		<result property="brandName"   column="brand_name"/>
		<result property="brandNameKo" column="brand_name_ko"/>
		<collection property="fuelTypes" ofType="String">
			<result column="fuel_type"/>
		</collection>
	</resultMap>

	<select id="selectAllBrands" resultMap="brandOptionResultMap">
		SELECT brand_id, brand_name
		FROM brand
		ORDER BY brand_id
	</select>

	<select id="selectVehiclesByBrandId" resultMap="vehicleResultMap">
		SELECT
			ve.vehicle_id, ve.vehicle_name, ve.vehicle_name_ko, ve.category, ve.segment, ve.body_type,
			ve.seating, ve.min_price, ve.max_price, ve.description, ve.summary,
			ve.brand_id, ve.brand_name, ve.brand_name_ko,
			vf.fuel_type
		FROM vehicle ve
		LEFT JOIN vehicle_type vf ON ve.vehicle_id = vf.vehicle_id
		WHERE ve.brand_id = #{brandId}
		ORDER BY ve.vehicle_id
	</select>

</mapper>
